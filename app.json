{
  "expo": {
    "name": "Random Gallery",
    "slug": "random-gallery",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/image.png",
    "scheme": "randomgallery",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/image.png",
        "monochromeImage": "./assets/images/image.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.lvlh2.randomgallery"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "android": {
            "image": "./assets/images/image.png",
            "imageWidth": 100
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3c1821ee-25b6-4d53-af20-36df49eac965"
      }
    }
  }
}
